{
  "name": "slimtable",
  "description": "jQuery plugin to create sortable and pageable table.",
  "version": "2.1.0",
  "author": "Pekka Harjamäki <mcfizh@gmail.com>",
  "homepage": "https://slimtable.mcfish.org",
  "license": "MIT",
  "keywords": [
    "table",
    "sorting",
    "paging",
    "ajax",
    "jquery-plugin",
    "ecosystem:jquery"
  ],
  "main": "dist/js/slimtable.min.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/McFizh/slimtable.git"
  },
  "scripts": {
    "test:lint": "eslint src/slimtable.js",
