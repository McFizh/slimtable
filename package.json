    "build": "rm -rf dist && node esbuild.config.js"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "esbuild": "^0.27.0",
    "eslint": "^10.0.0",
    "globals": "^17.0.0",
    "http-server": "^14.1.1",
    "puppeteer": "^24.25.0",
    "qunit": "^2.19.3"
  }
